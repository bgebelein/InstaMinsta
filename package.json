{
  "name": "quadra-cam",
  "version": "1.0.0",
  "description": "Instagram like camera app.",
  "keywords": [
    "instagram",
    "camera",
    "app",
    "pwa"
  ],
  "homepage": "https://github.com/bgebelein/InstaMinsta#readme",
  "bugs": {
    "url": "https://github.com/bgebelein/InstaMinsta/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bgebelein/InstaMinsta.git"
  },
  "license": "ISC",
  "author": "Bent Gebelein",
  "type": "commonjs",
  "main": "index.html",
  "scripts": {
    "tw-watch": "npx tailwindcss -i ./src/styles.css -o ./src/styles.min.css --watch",
    "minify-html": "html-minifier-terser --input-dir ./public --output-dir ./public --collapse-whitespace --remove-comments --sort-attributes --sort-class-name --file-ext html",
    "minify-css": "npx tailwindcss -i ./src/styles.css -o ./src/styles.min.css --minify",
    "minify-js": "uglifyjs ./public/script.js --compress --mangle --output ./public/script.js ",
    "build": "npm run minify-css && cpy \"**/*\" ../public --cwd=src && rm -f ./public/styles.css && npm run minify-html && npm run minify-js"
  },
  "devDependencies": {
    "cpy-cli": "^7.0.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwind-scrollbar": "^4.0.2"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "html-minifier-terser": "^7.2.0",
    "tailwind-css-instagram-filters": "^1.0.1",
    "tailwindcss": "^4.2.2",
    "uglify-js": "^3.19.3"
  }
}
