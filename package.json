{
  "name": "quadra-cam",
  "version": "1.0.0",
  "description": "Instagram like camera app.",
  "keywords": [
    "instagram",
    "camera",
    "app",
    "pwa"
  ],
  "homepage": "https://github.com/bgebelein/InstaMinsta#readme",
  "bugs": {
    "url": "https://github.com/bgebelein/InstaMinsta/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bgebelein/InstaMinsta.git"
  },
  "license": "ISC",
  "author": "Bent Gebelein",
  "type": "commonjs",
  "main": "index.html",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "tw-watch": "npx tailwindcss -i ./src/styles.css -o ./src/styles.min.css --watch",
    "minify-css": "npx tailwindcss -i ./src/styles.css -o ./src/styles.min.css --minify",
    "build": "rm -f ./public/* && npm run minify-css && copyfiles -u 1 ./src/* ./public && rm -f ./public/styles.css"
  },
  "devDependencies": {
    "copyfiles": "^2.4.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwind-scrollbar": "^4.0.2"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "tailwindcss": "^4.2.2"
  }
}
